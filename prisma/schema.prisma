generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email       String    @unique
  studentCode String?
  password    String?
  phone       String?
  avatarUrl   String?
  provider    Provider  @default(LOCAL)
  providerId String?
  role       Role      @default(STUDENT)
  version    Int       @default(0)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  taughtClasses   Class[]          @relation("TeacherClasses")
  enrolledClasses ClassEnrollment[]
  scores          Score[]
  speakingResults SpeakingResult[]
  gamification    Gamification?
  auditLogs       AuditLog[]
  refreshTokens   RefreshToken[]
  vocabularyProgress UserVocabularyProgress[]
  exerciseProgress ExerciseProgress[]
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum Provider {
  LOCAL
  GOOGLE
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Class {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  classCode   String?
  description String?
  teacherId   String   @db.ObjectId
  teacher     User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  version     Int      @default(0)
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments ClassEnrollment[]
  exercises   Exercise[]
}

model ClassEnrollment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  classId   String   @db.ObjectId
  userId    String   @db.ObjectId
  class     Class    @relation(fields: [classId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  isDeleted Boolean  @default(false)
  deletedAt DateTime?
  joinedAt  DateTime @default(now())

  @@unique([classId, userId])
}

model Exercise {
  id         String         @id @default(auto()) @map("_id") @db.ObjectId
  classId    String         @db.ObjectId
  class      Class          @relation(fields: [classId], references: [id])
  title      String
  type       ExerciseType
  status     ExerciseStatus @default(DRAFT)
  gameConfig Json?
  version    Int            @default(0)
  isDeleted  Boolean        @default(false)
  deletedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  vocabulary      Vocabulary[]
  patterns        Pattern[]
  scores          Score[]
  speakingResults SpeakingResult[]
  exerciseProgress ExerciseProgress[]
}

enum ExerciseType {
  VOCAB
  PATTERN
  QUIZ
  SPEAKING
  MIXED
}

enum ExerciseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Vocabulary {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  exerciseId String   @db.ObjectId
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  word       String
  meaning    String
  audioUrl   String?
  imageUrl   String?
  isDeleted  Boolean  @default(false)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())

  userProgress UserVocabularyProgress[]
}

model Pattern {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  exerciseId  String   @db.ObjectId
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  sentence    String
  translation String
  audioUrl    String?
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
}

model Score {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  exerciseId  String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  score       Float
  completedAt DateTime @default(now())
}

model SpeakingResult {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  exerciseId String   @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  audioUrl   String
  aiScore    Float?
  feedback   String?
  createdAt  DateTime @default(now())
}

model Gamification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id])
  totalPoints Int      @default(0)
  stars       Int      @default(0)
  badges      Json     @default("[]")
  streak      Int      @default(0)
  version     Int      @default(0)
  lastActive  DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  target    String
  createdAt DateTime @default(now())
}

model OcrCache {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  imageHash      String   @unique
  engine         String
  structuredData Json
  hitCount       Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

// Cache BỀN VỮNG cho làm giàu từ vựng (dictionaryapi.dev) — mỗi từ 1 bản ghi, tái dùng mãi.
model DictionaryCache {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  word            String   @unique
  phonetic        String?
  audioUrl        String?
  partOfSpeech    String?
  definitionEn    String?
  exampleSentence String?
  hitCount        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Cache BỀN VỮNG cho bản dịch câu (MyMemory) — key = câu đã chuẩn hoá (lowercase/trim).
model TranslationCache {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  originalText   String   @unique
  translatedText String
  langPair       String   @default("en|vi")
  hitCount       Int      @default(0)
  createdAt      DateTime @default(now())
}

model UserVocabularyProgress {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  userId       String     @db.ObjectId
  user         User       @relation(fields: [userId], references: [id])
  vocabularyId String     @db.ObjectId
  vocabulary   Vocabulary @relation(fields: [vocabularyId], references: [id])
  level        Int        @default(0) // 0: new, 1: learning, 2: temp, 3: long, 4: mastered
  nextReview   DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, vocabularyId])
}

model ExerciseProgress {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  exerciseId  String   @db.ObjectId
  type        String   // "vocab_flashcard", "quiz", "sentence_arrange", etc.
  data        Json     // Stores: { currentIndex, answers: [], score, completed, ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id])
  exercise    Exercise @relation(fields: [exerciseId], references: [id])

  @@unique([userId, exerciseId, type])
}

